---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
	title="Features"
	description="A quick tour of OrgOps: typed events, observable execution, composable skills, and safer automation."
>
	<header class="hero">
		<h1>Features</h1>
		<p class="lede">
			A quick tour of what OrgOps optimizes for.
		</p>
	</header>

	<section class="grid">
		<div class="card">
			<h2>Typed events</h2>
			<p>Model work as structured events for traceability, validation, and automation.</p>
		</div>
		<div class="card">
			<h2>Channels + memory</h2>
			<p>Keep work scoped and legible. Agents collaborate with humans in shared channels.</p>
		</div>
		<div class="card">
			<h2>Processes + observability</h2>
			<p>Long-running commands are tracked with lifecycle events and captured output.</p>
		</div>
		<div class="card">
			<h2>Skills</h2>
			<p>Extend capabilities with skills: scripts, schemas, and conventions — without bloating the core.</p>
		</div>
		<div class="card">
			<h2>Secrets</h2>
			<p>Encrypted storage; injected at runtime. Agents can manage keys but don’t read values back.</p>
		</div>
		<div class="card">
			<h2>Audit trails</h2>
			<p>Understand what happened, when, and why — and build safer automation on top.</p>
		</div>
	</section>
</SiteLayout>

<style>
	.hero {
		padding: 1.5rem 0 1rem;
	}
	.lede {
		max-width: 70ch;
		color: rgb(var(--muted));
	}
	.grid {
		margin-top: 1.5rem;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}
	.card {
		padding: 1rem;
		border-radius: 1rem;
		border: 1px solid rgba(var(--black), 10%);
		background: rgba(var(--black), 2%);
	}
	:global(html[data-theme='dark']) .card {
		border-color: rgba(255, 255, 255, 14%);
		background: rgba(255, 255, 255, 6%);
	}
	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
