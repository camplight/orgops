---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<SiteLayout title="Blog">
	<h1>Blog</h1>
	<p>Updates, notes, and small write-ups about building and operating OrgOps.</p>

	<ul class="posts">
		{posts.map((post) => (
			<li class="post">
				<a class="post-link" href={`/blog/${post.id}/`}>
					<h2 class="title">{post.data.title}</h2>
					<p class="meta">
						<FormattedDate date={post.data.pubDate} />
						{post.data.description ? ` • ${post.data.description}` : ''}
					</p>
				</a>
			</li>
		))}
	</ul>
</SiteLayout>

<style>
	.posts {
		list-style: none;
		padding: 0;
		margin: 1.5rem 0 0;
		display: grid;
		gap: 0.75rem;
	}
	.post {
		border: 1px solid rgba(var(--black), 10%);
		border-radius: 1rem;
		background: rgba(var(--black), 2%);
	}
	:global(html[data-theme='dark']) .post {
		border-color: rgba(255, 255, 255, 14%);
		background: rgba(255, 255, 255, 6%);
	}
	.post-link {
		display: block;
		padding: 1rem;
		text-decoration: none;
	}
	.title {
		margin: 0;
		font-size: 1.1rem;
	}
	.meta {
		margin: 0.35rem 0 0;
		font-size: 0.95rem;
	}
</style>
