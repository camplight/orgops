---
import SiteLayout from '../layouts/SiteLayout.astro';
import { BRAND_ICON } from '../consts';
---

<SiteLayout
	description="OrgOps is an event-driven coordination layer for agent-driven work: typed events, observable execution, and composable skills."
>
	<section class="hero">
		<p class="kicker">{BRAND_ICON} orgops</p>
		<h1>Event-driven operations for teams.</h1>
		<p class="lede">
			OrgOps is a lightweight coordination layer for agent-driven work: typed events, observable execution, and
			composable skills.
		</p>
		<div class="cta">
			<a class="primary" href="/getting-started">Get started</a>
			<a class="secondary" href="/system">How it works</a>
		</div>
	</section>

	<section class="grid">
		<div class="card">
			<h2>Observable by design</h2>
			<p>See what happened: events, processes, and audit trails — without guesswork.</p>
		</div>
		<div class="card">
			<h2>Skills at the edges</h2>
			<p>Add integrations and automation as skills. Keep the core small and understandable.</p>
		</div>
		<div class="card">
			<h2>Human + agent coordination</h2>
			<p>Agents collaborate in channels with clear rules, explicit tools, and safe defaults.</p>
		</div>
	</section>
</SiteLayout>

<style>
	.hero {
		padding: 3rem 0 2rem;
	}
	.kicker {
		font-weight: 700;
		letter-spacing: 0.02em;
		opacity: 0.95;
	}
	.lede {
		max-width: 65ch;
		font-size: 1.1rem;
		opacity: 0.9;
	}
	.cta {
		margin-top: 1.25rem;
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.primary,
	.secondary {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 0.9rem;
		border-radius: 0.75rem;
		text-decoration: none;
		font-weight: 700;
	}
	.primary {
		background: var(--accent);
		color: white;
	}
	.secondary {
		border: 1px solid rgba(var(--black), 12%);
		color: var(--text);
		background: rgba(var(--black), 2%);
	}
	:global(html[data-theme='dark']) .secondary {
		border-color: rgba(255, 255, 255, 14%);
		background: rgba(255, 255, 255, 8%);
	}
	.grid {
		margin-top: 2rem;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}
	.card {
		padding: 1rem;
		border-radius: 1rem;
		border: 1px solid rgba(var(--black), 10%);
		background: rgba(var(--black), 2%);
	}
	:global(html[data-theme='dark']) .card {
		border-color: rgba(255, 255, 255, 14%);
		background: rgba(255, 255, 255, 6%);
	}
	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>
